# ---- App ----
APP_ENV=dev
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Backend ----
# For Docker compose, leave DATABASE_URL pointing to the db service.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cpi

# Comma-separated list
BACKEND_CORS_ORIGINS=http://localhost:5173

# Storage on disk (inside container). In non-docker, this can be ./storage
STORAGE_PATH=/app/storage

# Optional: generate with backend helper endpoint or python (see docs). If blank => no encryption.
# If set, must be a Fernet key (44 urlsafe base64 chars).
FILE_ENCRYPTION_KEY=

# ---- AI / LLM ----
# If empty, the assistant runs in local fallback mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Search / Retrieval ----
# Options: tfidf (default), sentence_transformers
EMBEDDING_PROVIDER=tfidf

# If EMBEDDING_PROVIDER=sentence_transformers:
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# How many chunks to retrieve for the assistant
ASSISTANT_TOP_K=5
